# Frontend env template for local dev (npm run dev fuera de Docker).
# Docker container reads these vars from docker-compose.yml.

VITE_API_URL=http://logs-api.localhost/api/v1

VITE_KEYCLOAK_URL=http://keycloak.localhost
VITE_KEYCLOAK_REALM=maya
VITE_KEYCLOAK_CLIENT_ID=maya-logs

VITE_DASHBOARD_API_URL=http://maya-dashboard-api.localhost
