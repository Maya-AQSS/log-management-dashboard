# Frontend env template for local dev (npm run dev fuera de Docker).
# Docker container reads these vars from docker-compose.yml.

VITE_API_URL=https://${HOST_PREFIX}logs-api.${DOMAIN_SUFFIX}/api/v1

VITE_KEYCLOAK_URL=https://keycloak.${DOMAIN_SUFFIX}
VITE_KEYCLOAK_REALM=${MAYA_SLOT}
VITE_KEYCLOAK_CLIENT_ID=maya-logs

VITE_DASHBOARD_API_URL=https://desarrollo-ceedcv-dashboard-api.192.168.2.1.nip.io
