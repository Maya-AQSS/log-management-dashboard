# ─── App ──────────────────────────────────────────────────────
APP_ENV=local
APP_KEY=
APP_URL=https://logs-api.maya.test

# ─── Base de datos (gestionada por infra/) ────────────────────
DB_DATABASE=log_mgmt_db
DB_USERNAME=log_mgmt_user
DB_PASSWORD=secret

# ─── Seeding ──────────────────────────────────────────────────
DB_SEED_MODE=if-empty

# ─── Puertos (acceso directo sin Traefik) ─────────────────────
BACKEND_PORT=8002
FRONTEND_PORT=5176

# ─── Variables de frontend (propagadas a frontend/.env por up.sh) ────
VITE_API_URL=https://logs-api.maya.test/api/v1
VITE_KEYCLOAK_URL=https://keycloak.maya.test
VITE_KEYCLOAK_REALM=maya
VITE_KEYCLOAK_CLIENT_ID=maya-logs
VITE_DASHBOARD_API_URL=https://dashboard-api.maya.test
