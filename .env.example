APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

# Conexión Laravel "panel" (config/database.php): usuario PostgreSQL con permisos mínimos.
# Crear el rol con database/sql/setup_panel_user.sql (como superusuario) y NO commitear
# contraseñas reales. Sustituir el placeholder del script antes de ejecutar en producción.
# En desarrollo habitual la app usa DB_USERNAME/DB_PASSWORD; DB_PANEL_* sirve para tests
# de integración (DatabaseConnectionTest) y para despliegues donde el panel use solo panel_user.
DB_PANEL_USERNAME=panel_user
DB_PANEL_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
# SESSION_SECURE_COOKIE: en producción/staging (HTTPS) true; la cookie solo se envía por TLS (mitiga robo de sesión por MITM).
# En local con HTTP, false; si es true el navegador no enviará la cookie.
SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE: en producción/staging usar strict. En local, lax suele bastar.
SESSION_SAME_SITE=strict
# SESSION_ENCRYPT: en producción/staging con driver database/redis usar true (cifrado del payload en almacenamiento).
# En local, false salvo que se quiera probar cifrado (requiere APP_KEY).
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

VIEW_COMPILED_PATH=/tmp/laravel-views

# Producción/staging: configurar AUTH_EXTERNAL_URL con la URL real del servicio de auth; 
# El valor por defecto es un placeholder para desarrollo local.
AUTH_EXTERNAL_URL=http://auth.example.com
AUTH_MOCK_USER_ID=1
