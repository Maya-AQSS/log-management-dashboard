APP_NAME="Log Management"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://logs.localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Base de datos (gestionada por infra/) ────────────────────
DB_CONNECTION=pgsql
DB_HOST=maya_infra_postgres
DB_PORT=5432
DB_DATABASE=log_mgmt_db
DB_USERNAME=log_mgmt_user
DB_PASSWORD=secret

# Control de seeders al arrancar (up.sh): always | if-empty | never
DB_SEED_MODE=if-empty

# Conexión Laravel "panel" (config/database.php): usuario PostgreSQL con permisos mínimos.
# Crear el rol con database/sql/setup_panel_user.sql (como superusuario) y NO commitear
# contraseñas reales. Sustituir el placeholder del script antes de ejecutar en producción.
# En desarrollo habitual la app usa DB_USERNAME/DB_PASSWORD; DB_PANEL_* sirve para tests
# de integración (DatabaseConnectionTest) y para despliegues donde el panel use solo panel_user.
DB_PANEL_USERNAME=panel_user
DB_PANEL_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
# SESSION_SECURE_COOKIE: en producción/staging (HTTPS) true; la cookie solo se envía por TLS.
# En local con HTTP, false; si es true el navegador no enviará la cookie.
SESSION_SECURE_COOKIE=false
# SESSION_SAME_SITE: en producción/staging usar strict. En local, lax suele bastar.
SESSION_SAME_SITE=lax
# SESSION_ENCRYPT: en producción/staging con driver database/redis usar true.
# En local, false salvo que se quiera probar cifrado (requiere APP_KEY).
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

VIEW_COMPILED_PATH=/tmp/laravel-views

# ─── Auth (gateway externo — maya_authorization) ──────────────
# En local: apunta al contenedor Docker del backend de maya_authorization.
# En producción/staging: configurar con la URL real del servicio de auth.
AUTH_EXTERNAL_URL=http://maya_auth_backend:8000
AUTH_MOCK_USER_ID=1

# ─── Puertos (acceso directo sin Traefik) ─────────────────────
BACKEND_PORT=8002
VITE_PORT=5176
